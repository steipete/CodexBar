<Window x:Class="CodexBarTray.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar Settings" Height="640" Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#FF15151A" Foreground="#FFF2F2F4"
        FontFamily="Segoe UI" FontSize="12">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <SolidColorBrush x:Key="CardBg" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="TextDim" Color="#FF9A9AA2" />
        <SolidColorBrush x:Key="Accent" Color="#FF16D3B4" />

        <Style TargetType="Button" x:Key="SaveButton">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="#FF0A0A0C" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ProviderRow">
            <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                <StackPanel>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AuthLabel}" Foreground="{StaticResource TextDim}" FontSize="10"
                                       Visibility="{Binding ShowAuthLabel, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <CheckBox Content="Enabled" IsChecked="{Binding Enabled, Mode=OneWay}"
                                  Click="OnEnabledClick" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Foreground="{StaticResource TextDim}" />
                    </Grid>
                    <Grid Margin="0,8,0,0" Visibility="{Binding ShowKeyField, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="KeyBox" Grid.Column="0" Height="26" VerticalContentAlignment="Center"
                                     Background="#FF0E0E12" Foreground="#FFF2F2F4" BorderBrush="#33FFFFFF"
                                     Padding="6,0" Margin="0,0,8,0" />
                        <Button Grid.Column="1" Content="Save" Style="{StaticResource SaveButton}"
                                CommandParameter="{Binding ElementName=KeyBox}" Click="OnSaveKeyClick" />
                    </Grid>
                    <TextBlock Text="{Binding KeyHint}" Foreground="{StaticResource TextDim}" FontSize="10"
                               Margin="0,4,0,0"
                               Visibility="{Binding ShowKeyField, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource Accent}" FontSize="10"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="Notifications" FontSize="16" FontWeight="Bold" />
            <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="10,8" Margin="0,6,0,0">
                <StackPanel>
                    <CheckBox x:Name="SessionNotifyCheck" Content="Session depleted / restored alerts"
                              Foreground="{StaticResource TextDim}" Click="OnNotificationToggleChanged" />
                    <CheckBox x:Name="WarningNotifyCheck" Content="Quota low warnings" Margin="0,6,0,0"
                              Foreground="{StaticResource TextDim}" Click="OnNotificationToggleChanged" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Warn at (% left):" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextDim}" Margin="0,0,8,0" />
                        <TextBox x:Name="ThresholdsBox" Grid.Column="1" Height="26" VerticalContentAlignment="Center"
                                 Background="#FF0E0E12" Foreground="#FFF2F2F4" BorderBrush="#33FFFFFF"
                                 Padding="6,0" LostFocus="OnThresholdsChanged" />
                    </Grid>
                    <TextBlock Foreground="{StaticResource TextDim}" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"
                               Text="Comma-separated percentages (e.g. 50, 20). You're warned once each time remaining quota drops past a threshold." />
                </StackPanel>
            </Border>

            <TextBlock Text="Providers" FontSize="16" FontWeight="Bold" Margin="0,14,0,0" />
            <TextBlock Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                       Text="Toggle providers and set API keys. Providers marked OAuth/CLI sign in automatically; cookie-based providers aren't fully supported on Windows yet." />
        </StackPanel>
        <TextBlock x:Name="GlobalStatus" DockPanel.Dock="Bottom" Foreground="{StaticResource TextDim}"
                   FontSize="10" Margin="0,8,0,0" />
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ProviderList" ItemTemplate="{StaticResource ProviderRow}" />
        </ScrollViewer>
    </DockPanel>
</Window>
