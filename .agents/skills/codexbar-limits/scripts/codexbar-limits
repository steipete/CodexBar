#!/usr/bin/env python3
"""Safe read-only helper for CodexBar limits and usage."""

from __future__ import annotations

import argparse
import json
import os
import re
import signal
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Sequence


SCRIPT_NAME = "codexbar-limits"
PLACEHOLDER_EMAIL = "<redacted:email>"
PLACEHOLDER_IDENTITY = "<redacted:identity>"
PLACEHOLDER_SECRET = "<redacted:secret>"

ANSI_RE = re.compile(r"\x1B\[[0-?]*[ -/]*[@-~]")
EMAIL_RE = re.compile(r"\b[A-Z0-9._%+\-]+@[A-Z0-9.\-]+\.[A-Z]{2,}\b", re.I)
BEARER_RE = re.compile(r"(?i)\bbearer\s+[A-Z0-9._~+/=-]+\b")
LABELED_SECRET_RE = re.compile(
    r"(?i)\b("
    r"authorization|api[_-]?key|access[_-]?token|refresh[_-]?token|id[_-]?token|"
    r"session(?:id)?|secret|password|passwd|cookie|set-cookie"
    r")\b(\s*[:=]\s*)([^\s,;]+)"
)
WORD_SECRET_RE = re.compile(
    r"(?i)\b(token|secret|password|passwd|cookie)\s+([A-Z0-9._~+/=-]{6,})\b"
)
JWT_RE = re.compile(r"\beyJ[A-Za-z0-9_\-]+?\.[A-Za-z0-9_\-]+?\.[A-Za-z0-9_\-]+?\b")
SECRET_KEY_RE = re.compile(
    r"(?i)(token|secret|api[_-]?key|authorization|cookie|password|passwd|session)"
)

IDENTITY_KEYS = {
    "accountemail",
    "accountorganization",
    "email",
    "organization",
    "providerid",
    "userid",
    "accountid",
    "username",
    "accountname",
}

PROVIDER_ALIASES = {
    "abacus": ["abacus", "abacusai"],
    "alibaba": ["alibaba", "alibaba-coding-plan"],
    "alibabatokenplan": ["alibabatokenplan", "alibaba-token-plan"],
    "azureopenai": ["azureopenai", "azure-openai"],
    "groq": ["groq", "groqcloud"],
    "opencodego": ["opencodego", "opencode-go"],
}

CODEXBAR_ENV_VAR = "CODEXBAR_LIMITS_CODEXBAR"
SKIP_DEFAULT_DISCOVERY_ENV_VAR = "CODEXBAR_LIMITS_SKIP_DEFAULT_DISCOVERY"
TIMEOUT_ENV_VAR = "CODEXBAR_LIMITS_TIMEOUT"
DEFAULT_TIMEOUT_SECONDS = 120.0


@dataclass(frozen=True)
class CodexBarBinary:
    path: str | None
    source: str | None
    checked: list[str]


@dataclass(frozen=True)
class UpstreamResult:
    argv: list[str]
    returncode: int
    stdout: str
    stderr: str
    timed_out: bool = False


def normalize_key(value: str) -> str:
    return re.sub(r"[^a-z0-9]+", "", value.lower())


def titleize_provider(provider: str | None) -> str | None:
    if provider is None:
        return None
    text = provider.replace("-", " ").replace("_", " ")
    return " ".join(part.capitalize() for part in text.split())


def is_secret_key(key: str | None) -> bool:
    if not key:
        return False
    return bool(SECRET_KEY_RE.search(key))


def is_identity_key(key: str | None) -> bool:
    if not key:
        return False
    return normalize_key(key) in IDENTITY_KEYS


def strip_ansi(text: str) -> str:
    return ANSI_RE.sub("", text)


def redact_secret_substrings(text: str) -> str:
    text = LABELED_SECRET_RE.sub(lambda match: f"{match.group(1)}{match.group(2)}{PLACEHOLDER_SECRET}", text)
    text = BEARER_RE.sub(f"Bearer {PLACEHOLDER_SECRET}", text)
    text = WORD_SECRET_RE.sub(lambda match: f"{match.group(1)} {PLACEHOLDER_SECRET}", text)
    text = JWT_RE.sub(PLACEHOLDER_SECRET, text)
    return text


def sanitize_text(text: str, include_identities: bool) -> str:
    text = strip_ansi(text)
    text = redact_secret_substrings(text)
    if not include_identities:
        text = EMAIL_RE.sub(PLACEHOLDER_EMAIL, text)
    return text


def identity_placeholder_for(key: str | None) -> str:
    normalized = normalize_key(key or "")
    if "email" in normalized:
        return PLACEHOLDER_EMAIL
    return PLACEHOLDER_IDENTITY


def sanitize_value(value: Any, *, include_identities: bool, key: str | None = None) -> Any:
    if key and is_secret_key(key):
        return PLACEHOLDER_SECRET

    if isinstance(value, dict):
        return {
            str(child_key): sanitize_value(child_value, include_identities=include_identities, key=str(child_key))
            for child_key, child_value in value.items()
        }
    if isinstance(value, list):
        return [sanitize_value(item, include_identities=include_identities) for item in value]
    if isinstance(value, tuple):
        return [sanitize_value(item, include_identities=include_identities) for item in value]
    if isinstance(value, str):
        if key and is_identity_key(key) and not include_identities:
            return identity_placeholder_for(key)
        return sanitize_text(value, include_identities=include_identities)
    if key and is_identity_key(key) and value is not None and not include_identities:
        return identity_placeholder_for(key)
    return value


def truncate(text: str, max_length: int = 240) -> str:
    if len(text) <= max_length:
        return text
    return f"{text[: max_length - 1]}…"


def make_redaction_state(include_identities: bool) -> dict[str, bool]:
    return {"identities": not include_identities, "secrets": True}


def safe_install_path(path: str | None) -> str | None:
    if path is None:
        return None
    home = str(Path.home())
    if path == home:
        return "~"
    if path.startswith(f"{home}/"):
        return f"~/{path[len(home) + 1:]}"
    return re.sub(r"^/Users/[^/]+", "/Users/<redacted>", path)


def upstream_timeout_seconds() -> float:
    raw = os.environ.get(TIMEOUT_ENV_VAR)
    if raw is None:
        return DEFAULT_TIMEOUT_SECONDS
    try:
        value = float(raw)
    except ValueError:
        return DEFAULT_TIMEOUT_SECONDS
    return max(1.0, value)


def executable_path(path: Path) -> str | None:
    try:
        if path.is_file() and os.access(path, os.X_OK):
            return str(path)
    except OSError:
        return None
    return None


def caskroom_candidates() -> list[tuple[str, Path]]:
    candidates: list[tuple[str, Path]] = []
    for caskroom in (Path("/opt/homebrew/Caskroom/codexbar"), Path("/usr/local/Caskroom/codexbar")):
        if not caskroom.exists():
            continue
        for app in sorted(caskroom.glob("*/CodexBar.app")):
            candidates.append(("homebrew_cask_app", app / "Contents" / "Helpers" / "CodexBarCLI"))
    return candidates


def codexbar_candidates() -> list[tuple[str, Path]]:
    home = Path.home()
    candidates: list[tuple[str, Path]] = []

    override = os.environ.get(CODEXBAR_ENV_VAR)
    if override:
        candidates.append(("env_override", Path(override).expanduser()))

    path_hit = shutil.which("codexbar")
    if path_hit:
        candidates.append(("path", Path(path_hit)))

    if os.environ.get(SKIP_DEFAULT_DISCOVERY_ENV_VAR) == "1":
        return candidates

    candidates.extend(
        [
            ("homebrew_bin", Path("/opt/homebrew/bin/codexbar")),
            ("homebrew_bin", Path("/usr/local/bin/codexbar")),
            ("application_bundle", Path("/Applications/CodexBar.app/Contents/Helpers/CodexBarCLI")),
            ("user_application_bundle", home / "Applications/CodexBar.app/Contents/Helpers/CodexBarCLI"),
        ]
    )
    candidates.extend(caskroom_candidates())
    return candidates


def resolve_codexbar() -> CodexBarBinary:
    checked: list[str] = []
    seen: set[str] = set()
    for source, candidate in codexbar_candidates():
        text = str(candidate)
        if text in seen:
            continue
        seen.add(text)
        checked.append(text)
        if executable_path(candidate):
            return CodexBarBinary(path=text, source=source, checked=checked)
    return CodexBarBinary(path=None, source=None, checked=checked)


def codexbar_missing_message() -> str:
    return (
        "CodexBar CLI was not found. Install CodexBar with `brew install --cask codexbar`, "
        "download CodexBar.app from GitHub Releases, then use Preferences > Advanced > Install CLI "
        "or set CODEXBAR_LIMITS_CODEXBAR to the CodexBarCLI binary."
    )


def run_upstream(argv: Sequence[str]) -> UpstreamResult:
    process = subprocess.Popen(
        list(argv),
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        start_new_session=True,
    )
    try:
        stdout, stderr = process.communicate(timeout=upstream_timeout_seconds())
    except subprocess.TimeoutExpired:
        try:
            os.killpg(process.pid, signal.SIGTERM)
        except ProcessLookupError:
            pass
        try:
            stdout, stderr = process.communicate(timeout=2)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(process.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
            stdout, stderr = process.communicate()
        return UpstreamResult(
            argv=list(argv),
            returncode=124,
            stdout=stdout or "",
            stderr=stderr or "",
            timed_out=True,
        )
    return UpstreamResult(
        argv=list(argv),
        returncode=process.returncode,
        stdout=stdout or "",
        stderr=stderr or "",
    )


def base_envelope(
    *,
    name: str,
    scope: str | None,
    provider: str | None,
    include_identities: bool,
    raw_requested: bool,
    codexbar: CodexBarBinary,
) -> dict[str, Any]:
    return {
        "ok": True,
        "command": {
            "name": name,
            "scope": scope,
            "provider": provider,
            "raw": raw_requested,
            "include_identities": include_identities,
        },
        "codexbar_available": codexbar.path is not None,
        "codexbar": {
            "path": safe_install_path(codexbar.path),
            "source": codexbar.source,
            "checked": [safe_install_path(path) for path in codexbar.checked],
        },
        "providers": [],
        "usage": [],
        "errors": [],
        "warnings": [],
        "redacted": make_redaction_state(include_identities),
    }


def add_error(
    envelope: dict[str, Any],
    *,
    classification: str,
    message: str,
    provider: str | None = None,
    exit_code: int | None = None,
    severity: str = "error",
) -> None:
    item: dict[str, Any] = {
        "classification": classification,
        "message": truncate(message),
        "severity": severity,
    }
    if provider:
        item["provider"] = provider
    if exit_code is not None:
        item["exit_code"] = exit_code
    envelope["errors"].append(item)
    envelope["ok"] = False


def add_warning(
    envelope: dict[str, Any],
    *,
    classification: str,
    message: str,
    provider: str | None = None,
    severity: str = "warning",
) -> None:
    item: dict[str, Any] = {
        "classification": classification,
        "message": truncate(message),
        "severity": severity,
    }
    if provider:
        item["provider"] = provider
    envelope["warnings"].append(item)


def add_timeout_error(
    envelope: dict[str, Any],
    *,
    result: UpstreamResult,
    context: str,
) -> None:
    add_error(
        envelope,
        classification="upstream_timeout",
        message=f"codexbar {context} exceeded {upstream_timeout_seconds():g}s and was stopped.",
        exit_code=result.returncode,
    )


def has_errors(
    envelope: dict[str, Any],
    *,
    ignore_classifications: set[str] | None = None,
) -> bool:
    ignored = ignore_classifications or set()
    return any(item.get("classification") not in ignored for item in envelope["errors"])


def parse_json_stdout(
    envelope: dict[str, Any],
    result: UpstreamResult,
    *,
    context: str,
    include_identities: bool,
) -> Any | None:
    stdout = result.stdout.strip()
    if not stdout:
        add_error(
            envelope,
            classification="empty_stdout",
            message=f"codexbar {context} produced no JSON on stdout.",
            exit_code=result.returncode,
        )
        return None
    try:
        return json.loads(stdout)
    except json.JSONDecodeError as exc:
        preview = sanitize_text(result.stdout[:400], include_identities=False)
        add_error(
            envelope,
            classification="invalid_json",
            message=f"codexbar {context} returned invalid JSON: {exc.msg}. stdout={preview!r}",
            exit_code=result.returncode,
        )
        return None


def provider_aliases(provider: str) -> list[str]:
    aliases = PROVIDER_ALIASES.get(provider, [provider, provider.replace("-", ""), provider.replace("_", "")])
    deduped: list[str] = []
    for alias in aliases:
        alias = alias.lower()
        if alias and alias not in deduped:
            deduped.append(alias)
    return deduped


def infer_provider(text: str, known_providers: Sequence[str]) -> str | None:
    lowered = strip_ansi(text).lower()
    prefix_match = re.match(r"^\[([a-z0-9_-]+) stderr\]", lowered)
    if prefix_match:
        prefix = prefix_match.group(1)
        for provider in known_providers:
            if prefix == provider or prefix in provider_aliases(provider):
                return provider
    for provider in sorted(known_providers, key=len, reverse=True):
        for alias in provider_aliases(provider):
            if re.search(rf"(?<![a-z0-9]){re.escape(alias)}(?![a-z0-9])", lowered):
                return provider
    return None


def classify_stderr(
    envelope: dict[str, Any],
    *,
    stderr: str,
    include_identities: bool,
    treat_as_error: bool,
    known_providers: Sequence[str],
) -> None:
    for raw_line in stderr.splitlines():
        if not raw_line.strip():
            continue
        severity = "warning"
        provider = infer_provider(raw_line, known_providers)
        message = raw_line
        try:
            payload = json.loads(raw_line)
        except json.JSONDecodeError:
            payload = None
        if isinstance(payload, dict):
            severity = str(payload.get("level") or "warning").lower()
            provider = provider or infer_provider(
                " ".join(
                    str(payload.get(key, ""))
                    for key in (
                        "label",
                        "message",
                        "provider",
                        "source",
                    )
                ),
                known_providers,
            )
            message = str(payload.get("message") or raw_line)
        safe_message = sanitize_text(message, include_identities=include_identities)
        if treat_as_error and severity in {"error", "critical"}:
            add_error(
                envelope,
                classification="upstream_stderr",
                message=safe_message,
                provider=provider,
                severity=severity,
            )
        else:
            add_warning(
                envelope,
                classification="upstream_stderr",
                message=safe_message,
                provider=provider,
                severity=severity,
            )


def normalize_provider(item: Any) -> dict[str, Any]:
    if not isinstance(item, dict):
        return {
            "provider": None,
            "display_name": None,
            "enabled": None,
            "default_enabled": None,
        }
    provider = item.get("provider")
    display_name = item.get("displayName") or titleize_provider(str(provider) if provider is not None else None)
    return {
        "provider": str(provider) if provider is not None else None,
        "display_name": str(display_name) if display_name is not None else None,
        "enabled": bool(item.get("enabled")) if "enabled" in item else None,
        "default_enabled": bool(item.get("defaultEnabled")) if "defaultEnabled" in item else None,
    }


def normalize_identity(value: Any, include_identities: bool) -> Any:
    if not isinstance(value, dict):
        return None
    return {
        "account_email": sanitize_value(value.get("accountEmail"), include_identities=include_identities, key="accountEmail"),
        "login_method": sanitize_value(value.get("loginMethod"), include_identities=include_identities, key="loginMethod"),
        "provider_id": sanitize_value(value.get("providerID"), include_identities=include_identities, key="providerID"),
    }


def normalize_window(value: Any, include_identities: bool) -> Any:
    if not isinstance(value, dict):
        return None
    return {
        "window_minutes": value.get("windowMinutes"),
        "used_percent": value.get("usedPercent"),
        "resets_at": sanitize_value(value.get("resetsAt"), include_identities=include_identities, key="resetsAt"),
        "reset_description": sanitize_value(
            value.get("resetDescription"),
            include_identities=include_identities,
            key="resetDescription",
        ),
    }


def normalize_credits(value: Any, include_identities: bool) -> Any:
    if not isinstance(value, dict):
        return None
    return {
        "remaining": value.get("remaining"),
        "updated_at": sanitize_value(value.get("updatedAt"), include_identities=include_identities, key="updatedAt"),
        "events": sanitize_value(value.get("events") or [], include_identities=include_identities),
    }


def normalize_usage_details(value: Any, include_identities: bool) -> Any:
    if not isinstance(value, dict):
        return None
    return {
        "account_email": sanitize_value(value.get("accountEmail"), include_identities=include_identities, key="accountEmail"),
        "account_organization": sanitize_value(
            value.get("accountOrganization"),
            include_identities=include_identities,
            key="accountOrganization",
        ),
        "login_method": sanitize_value(value.get("loginMethod"), include_identities=include_identities, key="loginMethod"),
        "updated_at": sanitize_value(value.get("updatedAt"), include_identities=include_identities, key="updatedAt"),
        "primary": normalize_window(value.get("primary"), include_identities=include_identities),
        "secondary": normalize_window(value.get("secondary"), include_identities=include_identities),
        "tertiary": normalize_window(value.get("tertiary"), include_identities=include_identities),
        "extra_rate_windows": sanitize_value(
            value.get("extraRateWindows") or [],
            include_identities=include_identities,
        ),
        "provider_cost": sanitize_value(value.get("providerCost"), include_identities=include_identities, key="providerCost"),
        "identity": normalize_identity(value.get("identity"), include_identities=include_identities),
    }


def index_providers(providers: Sequence[dict[str, Any]]) -> dict[str, dict[str, Any]]:
    indexed: dict[str, dict[str, Any]] = {}
    for provider in providers:
        provider_id = provider.get("provider")
        if provider_id:
            indexed[str(provider_id)] = provider
    return indexed


def scope_provider_list(
    providers: Sequence[dict[str, Any]],
    *,
    scope: str,
    provider_id: str | None,
) -> list[dict[str, Any]]:
    if scope == "enabled":
        return [provider for provider in providers if provider.get("enabled")]
    if scope == "all":
        return list(providers)
    if scope == "provider" and provider_id:
        for provider in providers:
            if provider.get("provider") == provider_id:
                return [provider]
        return [
            {
                "provider": provider_id,
                "display_name": titleize_provider(provider_id),
                "enabled": None,
                "default_enabled": None,
            }
        ]
    return list(providers)


def load_provider_inventory(
    envelope: dict[str, Any],
    *,
    codexbar_path: str,
    include_identities: bool,
    raw_requested: bool,
) -> tuple[list[dict[str, Any]], Any | None]:
    result = run_upstream([codexbar_path, "config", "providers", "--format", "json", "--json-only"])
    if result.timed_out:
        add_timeout_error(envelope, result=result, context="config providers")
        return [], None
    raw_data = parse_json_stdout(
        envelope,
        result,
        context="config providers",
        include_identities=include_identities,
    )
    known_providers: list[str] = []
    providers: list[dict[str, Any]] = []
    if isinstance(raw_data, list):
        providers = [normalize_provider(item) for item in raw_data]
        known_providers = [provider["provider"] for provider in providers if provider.get("provider")]
    else:
        if raw_data is not None:
            add_error(
                envelope,
                classification="unexpected_shape",
                message="codexbar config providers did not return a JSON array.",
                exit_code=result.returncode,
            )
    classify_stderr(
        envelope,
        stderr=result.stderr,
        include_identities=include_identities,
        treat_as_error=result.returncode != 0,
        known_providers=known_providers,
    )
    if result.returncode != 0:
        add_error(
            envelope,
            classification="upstream_exit_nonzero",
            message="codexbar config providers exited non-zero.",
            exit_code=result.returncode,
        )
    raw_payload = sanitize_value(raw_data, include_identities=include_identities) if raw_requested else None
    return providers, raw_payload


def build_doctor_envelope(*, include_identities: bool, raw_requested: bool) -> tuple[dict[str, Any], int]:
    codexbar = resolve_codexbar()
    envelope = base_envelope(
        name="doctor",
        scope=None,
        provider=None,
        include_identities=include_identities,
        raw_requested=raw_requested,
        codexbar=codexbar,
    )
    envelope["doctor"] = {
        "codexbar_path": safe_install_path(codexbar.path),
        "codexbar_source": codexbar.source,
        "codexbar_version": None,
        "provider_count": 0,
        "enabled_provider_count": 0,
        "validation_issue_count": 0,
    }
    if not codexbar.path:
        add_error(
            envelope,
            classification="codexbar_missing",
            message=codexbar_missing_message(),
        )
        return envelope, 1

    version_result = run_upstream([codexbar.path, "--version"])
    if version_result.timed_out:
        add_timeout_error(envelope, result=version_result, context="--version")
    version_text = version_result.stdout.strip() or version_result.stderr.strip()
    if version_text:
        envelope["doctor"]["codexbar_version"] = sanitize_text(version_text, include_identities=True)
    if version_result.returncode != 0 and not version_result.timed_out:
        add_warning(
            envelope,
            classification="upstream_exit_nonzero",
            message="codexbar --version exited non-zero.",
        )

    providers, raw_providers = load_provider_inventory(
        envelope,
        codexbar_path=codexbar.path,
        include_identities=include_identities,
        raw_requested=raw_requested,
    )
    envelope["providers"] = providers
    envelope["doctor"]["provider_count"] = len(providers)
    envelope["doctor"]["enabled_provider_count"] = len([item for item in providers if item.get("enabled")])

    validate_result = run_upstream([codexbar.path, "config", "validate", "--format", "json", "--json-only"])
    if validate_result.timed_out:
        add_timeout_error(envelope, result=validate_result, context="config validate")
        issues = None
    else:
        issues = parse_json_stdout(
            envelope,
            validate_result,
            context="config validate",
            include_identities=include_identities,
        )
    known_providers = [provider["provider"] for provider in providers if provider.get("provider")]
    classify_stderr(
        envelope,
        stderr=validate_result.stderr,
        include_identities=include_identities,
        treat_as_error=False,
        known_providers=known_providers,
    )
    if isinstance(issues, list):
        envelope["doctor"]["validation_issue_count"] = len(issues)
        for issue in issues:
            if not isinstance(issue, dict):
                add_warning(
                    envelope,
                    classification="config_validation",
                    message=sanitize_text(str(issue), include_identities=include_identities),
                )
                continue
            severity = str(issue.get("severity") or "warning").lower()
            target = add_error if severity in {"error", "critical"} else add_warning
            target(
                envelope,
                classification="config_validation",
                message=sanitize_text(str(issue.get("message") or "Config validation issue."), include_identities),
                provider=issue.get("provider"),
                severity=severity,
            )
    elif issues is not None:
        add_error(
            envelope,
            classification="unexpected_shape",
            message="codexbar config validate did not return a JSON array.",
            exit_code=validate_result.returncode,
        )

    if not providers:
        add_warning(
            envelope,
            classification="provider_inventory_empty",
            message="No providers were returned by codexbar config providers.",
        )
    elif not any(provider.get("enabled") for provider in providers):
        add_warning(
            envelope,
            classification="no_enabled_providers",
            message="No providers are enabled in CodexBar.",
        )

    if raw_requested:
        envelope["raw"] = {
            "providers": raw_providers,
            "config_validate": sanitize_value(issues, include_identities=include_identities),
        }

    exit_code = 1 if has_errors(envelope, ignore_classifications={"config_validation"}) else 0
    return envelope, exit_code


def build_providers_envelope(*, include_identities: bool, raw_requested: bool) -> tuple[dict[str, Any], int]:
    codexbar = resolve_codexbar()
    envelope = base_envelope(
        name="providers",
        scope=None,
        provider=None,
        include_identities=include_identities,
        raw_requested=raw_requested,
        codexbar=codexbar,
    )
    if not codexbar.path:
        add_error(
            envelope,
            classification="codexbar_missing",
            message=codexbar_missing_message(),
        )
        return envelope, 1

    providers, raw_providers = load_provider_inventory(
        envelope,
        codexbar_path=codexbar.path,
        include_identities=include_identities,
        raw_requested=raw_requested,
    )
    envelope["providers"] = providers
    if raw_requested:
        envelope["raw"] = {"providers": raw_providers}
    exit_code = 0 if not has_errors(envelope) else 1
    return envelope, exit_code


def usage_command_argv(codexbar_path: str, scope: str, provider_id: str | None) -> list[str]:
    argv = [codexbar_path, "usage", "--format", "json", "--json-only"]
    if scope == "all":
        argv.extend(["--provider", "all"])
    elif scope == "provider" and provider_id:
        argv.extend(["--provider", provider_id])
    return argv


def normalize_usage_entry(
    item: Any,
    provider_meta: dict[str, Any] | None,
    *,
    include_identities: bool,
) -> dict[str, Any]:
    item = item if isinstance(item, dict) else {}
    provider_id = item.get("provider") or (provider_meta or {}).get("provider")
    provider_text = str(provider_id) if provider_id is not None else None
    display_name = (provider_meta or {}).get("display_name") or titleize_provider(provider_text)
    usage_details = normalize_usage_details(item.get("usage"), include_identities=include_identities)
    credits = normalize_credits(item.get("credits"), include_identities=include_identities)
    upstream_error = item.get("error")
    normalized_error = (
        sanitize_value(upstream_error, include_identities=include_identities, key="error")
        if upstream_error is not None
        else None
    )
    return {
        "provider": provider_text,
        "display_name": display_name,
        "enabled": (provider_meta or {}).get("enabled"),
        "default_enabled": (provider_meta or {}).get("default_enabled"),
        "status": "error" if normalized_error is not None else "ok" if usage_details is not None or credits is not None else "no-data",
        "source": sanitize_value(item.get("source"), include_identities=include_identities, key="source"),
        "usage": usage_details,
        "credits": credits,
        "error": normalized_error,
    }


def build_usage_envelope(
    *,
    scope: str,
    provider_id: str | None,
    include_identities: bool,
    raw_requested: bool,
) -> tuple[dict[str, Any], int]:
    codexbar = resolve_codexbar()
    envelope = base_envelope(
        name="usage",
        scope=scope,
        provider=provider_id,
        include_identities=include_identities,
        raw_requested=raw_requested,
        codexbar=codexbar,
    )
    if not codexbar.path:
        add_error(
            envelope,
            classification="codexbar_missing",
            message=codexbar_missing_message(),
        )
        return envelope, 1

    providers, raw_providers = load_provider_inventory(
        envelope,
        codexbar_path=codexbar.path,
        include_identities=include_identities,
        raw_requested=raw_requested,
    )
    providers_by_id = index_providers(providers)
    scoped_providers = scope_provider_list(providers, scope=scope, provider_id=provider_id)
    envelope["providers"] = scoped_providers

    if scope == "provider" and provider_id and provider_id not in providers_by_id:
        add_warning(
            envelope,
            classification="provider_not_in_inventory",
            message=f"Provider {provider_id!r} was not present in codexbar config providers.",
            provider=provider_id,
        )
    if scope == "enabled" and not scoped_providers:
        add_warning(
            envelope,
            classification="no_enabled_providers",
            message="No providers are enabled in CodexBar.",
        )
        if raw_requested:
            envelope["raw"] = {"providers": raw_providers, "usage": []}
        return envelope, 1 if has_errors(envelope) else 0

    result = run_upstream(usage_command_argv(codexbar.path, scope, provider_id))
    if result.timed_out:
        add_timeout_error(envelope, result=result, context="usage")
        raw_usage = None
    else:
        raw_usage = parse_json_stdout(
            envelope,
            result,
            context="usage",
            include_identities=include_identities,
        )

    known_providers = [provider["provider"] for provider in providers if provider.get("provider")]
    classify_stderr(
        envelope,
        stderr=result.stderr,
        include_identities=include_identities,
        treat_as_error=result.returncode != 0,
        known_providers=known_providers,
    )

    if result.returncode != 0 and not result.timed_out:
        add_error(
            envelope,
            classification="upstream_exit_nonzero",
            message="codexbar usage exited non-zero. Partial provider data may still be present in `usage`.",
            exit_code=result.returncode,
        )

    entries: list[dict[str, Any]] = []
    seen: set[str] = set()
    if isinstance(raw_usage, list):
        for item in raw_usage:
            normalized = normalize_usage_entry(
                item,
                providers_by_id.get(item.get("provider")) if isinstance(item, dict) else None,
                include_identities=include_identities,
            )
            provider_name = normalized.get("provider")
            if provider_name:
                seen.add(provider_name)
            if normalized.get("error") is not None:
                add_error(
                    envelope,
                    classification="provider_usage_error",
                    message=json.dumps(normalized["error"], sort_keys=True),
                    provider=provider_name,
                )
            entries.append(normalized)
    elif raw_usage is not None:
        add_error(
            envelope,
            classification="unexpected_shape",
            message="codexbar usage did not return a JSON array.",
            exit_code=result.returncode,
        )

    if isinstance(raw_usage, list):
        for provider in scoped_providers:
            provider_name = provider.get("provider")
            if not provider_name or provider_name in seen:
                continue
            entries.append(
                {
                    "provider": provider_name,
                    "display_name": provider.get("display_name"),
                    "enabled": provider.get("enabled"),
                    "default_enabled": provider.get("default_enabled"),
                    "status": "missing",
                    "source": None,
                    "usage": None,
                    "credits": None,
                }
            )
            add_warning(
                envelope,
                classification="expected_provider_missing",
                message=f"No usage record was returned for provider {provider_name!r}.",
                provider=provider_name,
            )

    if scope == "enabled":
        scoped_ids = {provider.get("provider") for provider in scoped_providers if provider.get("provider")}
        entries = [item for item in entries if item.get("provider") in scoped_ids]
    elif scope == "provider" and provider_id:
        entries = [item for item in entries if item.get("provider") == provider_id]

    envelope["usage"] = entries
    if raw_requested:
        envelope["raw"] = {
            "providers": raw_providers,
            "usage": sanitize_value(raw_usage, include_identities=include_identities),
        }
    return envelope, 0 if result.returncode == 0 and not has_errors(envelope) else 1


def render_summary(envelope: dict[str, Any]) -> str:
    command = envelope["command"]
    lines = [
        "CodexBar limits summary",
        f"Scope: {command['scope'] or 'enabled'}",
    ]
    if not envelope.get("codexbar_available"):
        lines.append("CodexBar: missing")
    else:
        codexbar = envelope.get("codexbar") or {}
        source = codexbar.get("source") or "unknown"
        lines.append(f"CodexBar: {codexbar.get('path') or 'available'} ({source})")
        lines.append(f"Providers checked: {len(envelope.get('providers', []))}")

    usage_entries = envelope.get("usage", [])
    if not usage_entries:
        lines.append("No usage data returned.")
    else:
        lines.append("")
        for entry in usage_entries:
            provider_name = entry.get("display_name") or entry.get("provider") or "unknown"
            line = f"- {provider_name} ({entry.get('provider') or 'unknown'}): {entry.get('status')}"
            details: list[str] = []
            if entry.get("source"):
                details.append(f"source={entry['source']}")
            usage = entry.get("usage") or {}
            for label in ("primary", "secondary", "tertiary"):
                window = usage.get(label) if isinstance(usage, dict) else None
                if isinstance(window, dict) and (
                    window.get("used_percent") is not None or window.get("window_minutes") is not None
                ):
                    parts = []
                    if window.get("used_percent") is not None:
                        parts.append(f"{window['used_percent']}% used")
                    if window.get("window_minutes") is not None:
                        parts.append(f"{window['window_minutes']}m window")
                    if window.get("resets_at"):
                        parts.append(f"resets {window['resets_at']}")
                    details.append(f"{label} {'; '.join(parts)}")
            credits = entry.get("credits") or {}
            if isinstance(credits, dict) and credits.get("remaining") is not None:
                detail = f"credits {credits['remaining']} remaining"
                if credits.get("updated_at"):
                    detail += f" (updated {credits['updated_at']})"
                details.append(detail)
            if details:
                line += " | " + " | ".join(details)
            lines.append(line)

    if envelope.get("warnings"):
        lines.extend(["", "Warnings:"])
        for item in envelope["warnings"]:
            provider = f"[{item['provider']}] " if item.get("provider") else ""
            lines.append(f"- {provider}{item['classification']}: {item['message']}")

    if envelope.get("errors"):
        lines.extend(["", "Errors:"])
        for item in envelope["errors"]:
            provider = f"[{item['provider']}] " if item.get("provider") else ""
            lines.append(f"- {provider}{item['classification']}: {item['message']}")

    return "\n".join(lines)


def print_json(payload: dict[str, Any]) -> None:
    print(json.dumps(payload, indent=2, sort_keys=True))


def add_json_flags(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--json", action="store_true", dest="as_json", help="Emit a stable JSON envelope.")
    parser.add_argument(
        "--raw",
        action="store_true",
        help="Include sanitized upstream payloads. Sensitive, use only with explicit need.",
    )
    parser.add_argument(
        "--include-identities",
        action="store_true",
        help="Expose identity-bearing fields such as account emails and org names. Sensitive.",
    )


def require_json(args: argparse.Namespace, parser: argparse.ArgumentParser) -> None:
    if not getattr(args, "as_json", False):
        parser.error("this command requires --json; use `summary` for human-readable output")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog=SCRIPT_NAME,
        description=(
            "Read-only CodexBar wrapper that emits stable JSON and redacts identity-bearing data by default."
        ),
        epilog=(
            "Sensitive flags: --raw includes sanitized upstream payloads, and --include-identities exposes "
            "identity-bearing fields. Auth repair and config writes are intentionally out of scope."
        ),
    )
    subparsers = parser.add_subparsers(dest="command_name", required=True)

    doctor = subparsers.add_parser("doctor", help="Inspect CodexBar availability and config health.")
    add_json_flags(doctor)

    providers = subparsers.add_parser("providers", help="List provider inventory from CodexBar config.")
    add_json_flags(providers)

    usage = subparsers.add_parser("usage", help="Read provider usage and quota windows.")
    scope_group = usage.add_mutually_exclusive_group(required=True)
    scope_group.add_argument("--enabled", action="store_true", help="Query enabled providers only.")
    scope_group.add_argument("--all", action="store_true", help="Query every configured provider.")
    scope_group.add_argument("--provider", help="Query one provider by stable provider id.")
    add_json_flags(usage)

    subparsers.add_parser("summary", help="Print a human-readable summary for enabled providers.")
    return parser


def main(argv: Sequence[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.command_name == "doctor":
        require_json(args, parser)
        envelope, exit_code = build_doctor_envelope(
            include_identities=args.include_identities,
            raw_requested=args.raw,
        )
        print_json(envelope)
        return exit_code

    if args.command_name == "providers":
        require_json(args, parser)
        envelope, exit_code = build_providers_envelope(
            include_identities=args.include_identities,
            raw_requested=args.raw,
        )
        print_json(envelope)
        return exit_code

    if args.command_name == "usage":
        require_json(args, parser)
        if args.enabled:
            scope = "enabled"
            provider_id = None
        elif args.all:
            scope = "all"
            provider_id = None
        else:
            scope = "provider"
            provider_id = args.provider
        envelope, exit_code = build_usage_envelope(
            scope=scope,
            provider_id=provider_id,
            include_identities=args.include_identities,
            raw_requested=args.raw,
        )
        print_json(envelope)
        return exit_code

    if args.command_name == "summary":
        envelope, exit_code = build_usage_envelope(
            scope="enabled",
            provider_id=None,
            include_identities=False,
            raw_requested=False,
        )
        print(render_summary(envelope))
        return exit_code

    parser.error("unknown command")
    return 2


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print(f"{SCRIPT_NAME}: interrupted", file=sys.stderr)
        raise SystemExit(130)
