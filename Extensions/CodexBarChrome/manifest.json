{
  "manifest_version": 3,
  "name": "CodexBar Usage Monitor",
  "version": "0.1.0",
  "description": "Quick model/provider usage from local CodexBar bridge.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "CodexBar Usage",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}